# 生产环境配置示例
# 复制为 .env 并填入实际值

# 服务端口
PORT=3001

# One-API 配置 (LLM API 代理)
ONE_API_BASE_URL=http://127.0.0.1:3002
ONE_API_ROOT_TOKEN=your-token-here

# 或者直接使用 LLM API
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# JWT 密钥 (如果需要用户认证)
JWT_SECRET=your-random-secret-key

# 数据库路径
DATABASE_PATH=./data/chat.db

# 日志级别
LOG_LEVEL=info

# CORS 允许的域名
CORS_ORIGIN=https://your-domain.com
