import { useState, useEffect, useRef } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import { socket } from '../services/api';
import { apiService } from '../services/api';

function ChatPage() {
  const navigate = useNavigate();
  const { roomId } = useParams();
  const [messages, setMessages] = useState([]);
  const [input, setInput] = useState('');
  const [agentList, setAgentList] = useState([]);
  const [loadingAgents, setLoadingAgents] = useState(true);
  const [chatroomInfo, setChatroomInfo] = useState({
    name: '#公共讨论区',
    type: 'free',
    description: '所有 Agent 都可以自由发言'
  });
  const [showEmojiPicker, setShowEmojiPicker] = useState(false);
  const [showImagePicker, setShowImagePicker] = useState(false);
  const [emojiList, setEmojiList] = useState([]);
  const [emojiGroups, setEmojiGroups] = useState({});
  const [uploadedImages, setUploadedImages] = useState([]);
  const [showRoomSettings, setShowRoomSettings] = useState(false);
  const [editRoomName, setEditRoomName] = useState('');
  const [editRoomDescription, setEditRoomDescription] = useState('');
  const [editRoomType, setEditRoomType] = useState('free');
  const fileInputRef = useRef(null);
  const messagesEndRef = useRef(null);

  const chatroomTypes = {
    free: { name: '自由聊天室', desc: '所有 Agent 都可以自由发言', color: 'bg-green-100 text-green-700' },
    '@only': { name: '需要 @ 的聊天室', desc: '@ Agent 来触发回复', color: 'bg-indigo-100 text-indigo-700' }
  };

  const currentChatroom = chatroomTypes[chatroomInfo.type] || chatroomTypes.free;

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  // 获取 Agent 列表
  useEffect(() => {
    const fetchAgents = async () => {
      try {
        const data = await apiService.getAgents();
        setAgentList(data.agents || []);
      } catch (error) {
        console.error('获取 agents 失败:', error);
      } finally {
        setLoadingAgents(false);
      }
    };

    fetchAgents();
  }, []);

  // 获取表情列表
  useEffect(() => {
    const fetchEmojis = async () => {
      try {
        const data = await apiService.getEmojis();
        setEmojiList(data.emojis || []);
        setEmojiGroups(data.groups || {});
      } catch (error) {
        console.error('获取表情列表失败:', error);
      }
    };

    fetchEmojis();
  }, []);

  // 获取已上传的图片
  useEffect(() => {
    const fetchImages = async () => {
      try {
        const data = await apiService.getUploadedImages();
        setUploadedImages(data.images || []);
      } catch (error) {
        console.error('获取图片列表失败:', error);
      }
    };

    fetchImages();
  }, []);

  // 获取房间信息
  useEffect(() => {
    const fetchRoomInfo = async () => {
      if (roomId) {
        try {
          const response = await apiService.getRoom(roomId);
          if (response.room) {
            setChatroomInfo({
              name: `#${response.room.name}`,
              type: response.room.type || 'free',
              description: response.room.description || ''
            });
            setEditRoomName(response.room.name);
            setEditRoomDescription(response.room.description || '');
            setEditRoomType(response.room.type || 'free');
          }
        } catch (error) {
          console.error('获取房间信息失败:', error);
        }
      }
    };
    fetchRoomInfo();
  }, [roomId]);

  // WebSocket 连接
  useEffect(() => {
    const room = roomId || 'general';
    socket.emit('joinRoom', { room });

    socket.on('messageReceived', (msg) => {
      setMessages(prev => [...prev, msg]);
    });

    return () => {
      socket.off('messageReceived');
    };
  }, [roomId]);

  // 获取历史消息
  useEffect(() => {
    const fetchMessages = async () => {
      const room = roomId || 'general';
      try {
        const data = await apiService.getRoomMessages(room);
        setMessages(data.messages || []);
      } catch (error) {
        console.error('获取历史消息失败:', error);
      }
    };
    fetchMessages();
  }, [roomId]);

  const sendMessage = (content, messageType = 'text', mediaUrl = null) => {
    const messageContent = content || input;
    if (!messageContent.trim() && !mediaUrl) return;

    const room = roomId || 'general';
    socket.emit('sendMessage', {
      room,
      sender: 'user',
      content: messageContent,
      messageType,
      mediaUrl
    });
    if (!mediaUrl) setInput('');
    setShowEmojiPicker(false);
  };

  // 处理 @ 提及
  const parseMentions = (text) => {
    const mentions = [];
    const mentionRegex = /@(\S+)/g;
    let match;
    while ((match = mentionRegex.exec(text)) !== null) {
      const mentionedName = match[1];
      const agent = agentList.find(a => a.name.includes(mentionedName) || a.id === mentionedName);
      if (agent) {
        mentions.push(agent.id);
      }
    }
    return mentions;
  };

  const handleKeyPress = (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  };

  // 处理表情选择
  const handleEmojiSelect = (emoji) => {
    setInput(prev => prev + emoji);
  };

  // 处理图片上传
  const handleImageUpload = async (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onloadend = async () => {
      try {
        const base64 = reader.result;
        const result = await apiService.uploadImage(base64, file.name);
        if (result.success) {
          // 发送图片消息
          sendMessage('', 'image', result.imageUrl);
          // 刷新图片列表
          const data = await apiService.getUploadedImages();
          setUploadedImages(data.images || []);
        }
      } catch (error) {
        console.error('上传图片失败:', error);
      }
    };
    reader.readAsDataURL(file);
    e.target.value = '';
  };

  // 处理图片点击发送
  const handleImageSelect = (imageUrl) => {
    sendMessage('', 'image', imageUrl);
    setShowImagePicker(false);
  };

  // 保存房间设置
  const handleSaveRoomSettings = async () => {
    try {
      // 这里需要后端 API 支持更新房间
      // 暂时只更新本地状态
      setChatroomInfo({
        name: `#${editRoomName}`,
        type: editRoomType,
        description: editRoomDescription
      });
      setShowRoomSettings(false);
      alert('房间设置已保存（演示模式）');
    } catch (error) {
      console.error('保存房间设置失败:', error);
    }
  };

  // 删除房间
  const handleDeleteRoom = async () => {
    if (!confirm('确定要删除这个聊天室吗？此操作不可恢复。')) return;

    try {
      await apiService.deleteRoom(roomId);
      alert('聊天室已删除');
      navigate('/admin');
    } catch (error) {
      console.error('删除房间失败:', error);
      alert('删除失败：' + error.message);
    }
  };

  // 加载中显示
  if (loadingAgents) {
    return (
      <div className="flex items-center justify-center h-screen">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mx-auto"></div>
          <p className="mt-4 text-gray-600">正在加载 Agent 列表...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="flex w-screen h-screen">
      {/* 聊天室信息侧边栏 */}
      <aside className="w-72 bg-white border-r border-gray-200 flex flex-col">
        {/* 聊天室头部 */}
        <div className="p-6 border-b border-gray-200">
          <div className="flex items-center justify-between mb-4">
            <h1 className="text-2xl font-bold text-gray-800">{chatroomInfo.name}</h1>
            <span className={`px-3 py-1 rounded-full text-xs font-medium ${currentChatroom.color}`}>
              {currentChatroom.name}
            </span>
          </div>
          <p className="text-gray-500 text-sm">{currentChatroom.desc}</p>
          {chatroomInfo.description && (
            <p className="text-xs text-gray-400 mt-2">{chatroomInfo.description}</p>
          )}
        </div>

        {/* Agent 列表 */}
        <div className="flex-1 overflow-y-auto p-4 space-y-3">
          <p className="text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">
            在线 Agent ({agentList.length})
          </p>
          <div className="space-y-2">
            {agentList.length > 0 ? (
              agentList.map(agent => (
                <div key={agent.id} className="flex items-center space-x-3 p-3 bg-gray-50 rounded-lg">
                  <div className={`w-10 h-10 ${agent.color || 'bg-blue-500'} rounded-full flex items-center justify-center`}>
                    <span className="text-white font-bold text-sm">{agent.avatar || agent.name.substring(0, 2)}</span>
                  </div>
                  <div>
                    <p className="font-medium text-gray-800 text-sm">{agent.name}</p>
                    {agent.status === 'online' && (
                      <p className="text-green-500 text-xs">● 在线</p>
                    )}
                    {agent.status === 'offline' && (
                      <p className="text-gray-400 text-xs">● 离线</p>
                    )}
                  </div>
                </div>
              ))
            ) : (
              <p className="text-gray-400 text-sm text-center">暂无可用 Agent</p>
            )}
          </div>
        </div>

        {/* 聊天室设置按钮 */}
        <div className="p-4 border-t border-gray-200 space-y-2">
          <button
            onClick={() => setShowRoomSettings(true)}
            className="w-full flex items-center justify-center space-x-2 px-4 py-2 text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition"
          >
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span className="text-sm">聊天室设置</span>
          </button>
          <button
            onClick={() => navigate('/admin')}
            className="w-full flex items-center justify-center space-x-2 px-4 py-2 text-gray-600 hover:text-indigo-600 hover:bg-indigo-50 rounded-lg transition"
          >
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z"></path>
            </svg>
            <span className="text-sm">返回管理</span>
          </button>
        </div>
      </aside>

      {/* 聊天主区域 */}
      <main className="flex-1 flex flex-col bg-white">
        {/* 聊天消息区域 */}
        <div className="flex-1 overflow-y-auto p-6 space-y-6">
          {/* 欢迎消息 */}
          {messages.length === 0 && (
            <div className="text-center text-gray-500 text-sm my-8">
              <p>欢迎来到 {chatroomInfo.name}</p>
              <p className="mt-2 text-xs">这里所有 Agent 都可以自由发言，你可以与任何 Agent 交互</p>
            </div>
          )}

          {/* 消息列表 */}
          {messages.map((msg, idx) => (
            <div key={idx} className={`flex ${msg.sender === 'user' ? 'justify-end' : 'justify-start'}`}>
              {msg.sender === 'user' ? (
                msg.messageType === 'image' ? (
                  <div className="max-w-[70%] bg-gradient-to-r from-indigo-500 to-purple-600 text-white rounded-2xl rounded-tr-sm px-4 py-2 shadow-sm">
                    <img src={msg.mediaUrl || msg.content} alt="图片消息" className="rounded-lg max-w-full h-auto" />
                    <p className="text-xs text-indigo-200 mt-2 text-right">
                      {msg.timestamp ? new Date(msg.timestamp).toLocaleTimeString() : '刚刚'}
                    </p>
                  </div>
                ) : (
                  <div className="max-w-[70%] bg-gradient-to-r from-indigo-500 to-purple-600 text-white rounded-2xl rounded-tr-sm px-6 py-4 shadow-sm">
                    <p className="text-sm">{msg.content}</p>
                    <p className="text-xs text-indigo-200 mt-2 text-right">
                      {msg.timestamp ? new Date(msg.timestamp).toLocaleTimeString() : '刚刚'}
                    </p>
                  </div>
                )
              ) : (
                <div className="flex items-start space-x-3">
                  <div className="w-8 h-8 bg-purple-500 rounded-full flex items-center justify-center flex-shrink-0">
                    <span className="text-white font-bold text-xs">
                      {agentList.find(a => a.id === msg.sender)?.avatar || (typeof msg.sender === 'string' ? msg.sender.substring(0, 1).toUpperCase() : 'A')}
                    </span>
                  </div>
                  <div>
                    {msg.messageType === 'image' ? (
                      <div className="bg-white rounded-2xl rounded-tl-sm px-4 py-2 shadow-sm border border-gray-100">
                        <img src={msg.mediaUrl || msg.content} alt="图片消息" className="rounded-lg max-w-xs h-auto" />
                      </div>
                    ) : (
                      <div className="bg-white rounded-2xl rounded-tl-sm px-5 py-4 shadow-sm border border-gray-100">
                        <p className="text-sm text-gray-800">{msg.content}</p>
                      </div>
                    )}
                    <p className="text-xs text-gray-400 mt-1 ml-1">
                      {agentList.find(a => a.id === msg.sender)?.name || msg.sender} ·
                      {msg.timestamp ? new Date(msg.timestamp).toLocaleTimeString() : '刚刚'}
                    </p>
                  </div>
                </div>
              )}
            </div>
          ))}
          <div ref={messagesEndRef} />
        </div>

        {/* 输入区域 */}
        <div className="p-6 bg-white border-t border-gray-200">
          {/* @ 提示 */}
          {chatroomInfo.type === '@only' && (
            <div className="mb-3 px-4 py-2 bg-indigo-50 rounded-lg">
              <p className="text-xs text-indigo-600 flex items-center">
                <svg className="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                @ Agent 来触发回复
              </p>
            </div>
          )}

          {/* 输入框 */}
          <div className="flex items-end space-x-3">
            <div className="flex-1 relative">
              <textarea
                rows="1"
                placeholder="输入消息..."
                className="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"
                value={input}
                onChange={(e) => setInput(e.target.value)}
                onInput={(e) => { e.target.style.height = ''; e.target.style.height = e.target.scrollHeight + 'px'; }}
                onKeyPress={handleKeyPress}
              ></textarea>
            </div>
            <button onClick={sendMessage} className="bg-gradient-to-r from-indigo-500 to-purple-600 text-white px-6 py-3 rounded-xl font-medium hover:shadow-lg transition flex items-center space-x-2">
              <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
              </svg>
              <span>发送</span>
            </button>
          </div>

          {/* 表情包和图片按钮 */}
          <div className="flex items-center space-x-4 mt-3">
            <div className="relative">
              <button
                onClick={() => { setShowEmojiPicker(!showEmojiPicker); setShowImagePicker(false); }}
                className="text-gray-400 hover:text-gray-600 transition"
              >
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </button>

              {/* 表情选择器 */}
              {showEmojiPicker && (
                <div className="absolute bottom-full left-0 mb-2 w-80 bg-white rounded-xl shadow-lg border border-gray-200 p-4 z-10">
                  <h4 className="font-medium text-gray-700 mb-3 text-sm">选择表情</h4>
                  <div className="grid grid-cols-8 gap-1 max-h-64 overflow-y-auto">
                    {emojiList.map((emoji, idx) => (
                      <button
                        key={idx}
                        onClick={() => handleEmojiSelect(emoji)}
                        className="text-xl hover:bg-gray-100 rounded p-1 transition"
                      >
                        {emoji}
                      </button>
                    ))}
                  </div>
                </div>
              )}
            </div>

            <div className="relative">
              <button
                onClick={() => { setShowImagePicker(!showImagePicker); setShowEmojiPicker(false); fileInputRef.current?.click(); }}
                className="text-gray-400 hover:text-gray-600 transition"
              >
                <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </button>
              <input
                ref={fileInputRef}
                type="file"
                accept="image/*"
                onChange={handleImageUpload}
                className="hidden"
              />

              {/* 图片选择器 */}
              {showImagePicker && (
                <div className="absolute bottom-full left-0 mb-2 w-80 bg-white rounded-xl shadow-lg border border-gray-200 p-4 z-10">
                  <h4 className="font-medium text-gray-700 mb-3 text-sm">已上传的图片</h4>
                  {uploadedImages.length > 0 ? (
                    <div className="grid grid-cols-3 gap-2 max-h-64 overflow-y-auto">
                      {uploadedImages.map((img, idx) => (
                        <button
                          key={idx}
                          onClick={() => handleImageSelect(img.url)}
                          className="aspect-square rounded-lg overflow-hidden hover:ring-2 hover:ring-indigo-500 transition"
                        >
                          <img src={img.url} alt={img.filename} className="w-full h-full object-cover" />
                        </button>
                      ))}
                    </div>
                  ) : (
                    <p className="text-gray-400 text-sm text-center py-4">暂无图片，点击左侧按钮上传</p>
                  )}
                </div>
              )}
            </div>

            <span className="text-xs text-gray-400">按 Enter 发送</span>
          </div>
        </div>
      </main>

      {/* 聊天室设置弹窗 */}
      {showRoomSettings && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div className="bg-white rounded-xl shadow-2xl w-full max-w-md p-6">
            <div className="flex items-center justify-between mb-6">
              <h3 className="text-xl font-bold text-gray-800">聊天室设置</h3>
              <button onClick={() => setShowRoomSettings(false)} className="text-gray-400 hover:text-gray-600">
                <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>

            <div className="space-y-4">
              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">聊天室名称</label>
                <input
                  type="text"
                  value={editRoomName}
                  onChange={(e) => setEditRoomName(e.target.value)}
                  className="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                />
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">聊天室类型</label>
                <select
                  value={editRoomType}
                  onChange={(e) => setEditRoomType(e.target.value)}
                  className="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                >
                  <option value="free">自由聊天室 - 所有 Agent 都可以发言</option>
                  <option value="@only">需要 @ - 只有@Agent 才会回复</option>
                </select>
              </div>

              <div>
                <label className="block text-sm font-medium text-gray-700 mb-1">聊天室描述</label>
                <textarea
                  rows="3"
                  value={editRoomDescription}
                  onChange={(e) => setEditRoomDescription(e.target.value)}
                  className="w-full border border-gray-300 rounded-lg px-3 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none"
                  placeholder="描述这个聊天室的用途..."
                />
              </div>
            </div>

            <div className="flex space-x-3 mt-6">
              <button
                onClick={handleSaveRoomSettings}
                className="flex-1 bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 transition"
              >
                保存设置
              </button>
              <button
                onClick={handleDeleteRoom}
                className="px-4 py-2 text-red-600 hover:bg-red-50 rounded-lg transition"
              >
                删除聊天室
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

export default ChatPage;
