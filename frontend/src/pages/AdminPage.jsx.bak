import { useState, useEffect } from 'react';
import { Link, useNavigate } from 'react-router-dom';
import { apiService } from '../services/api';
import { socket } from '../services/api';

function AdminPage() {
  const [stats, setStats] = useState({
    rooms: 0,
    messages: 0,
    bots: 0,
    onlineBots: 0,
    apiKeys: 0
  });
  const [bots, setBots] = useState([]);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    loadStats();
    loadBots();
    
    socket.on('botStatusUpdate', (data) => {
      setBots(prevBots => {
        const updatedBots = prevBots.map(bot => 
          bot.id === data.botId ? { ...bot, status: data.status } : bot
        );
        return updatedBots;
      });
    });
    
    return () => {
      socket.off('botStatusUpdate');
    };
  }, []);

  const loadStats = async () => {
    try {
      const response = await apiService.getStats();
      setStats(response.stats || {
        rooms: 0,
        messages: 0,
        bots: 0,
        onlineBots: 0,
        apiKeys: 0
      });
    } catch (error) {
      console.error('Failed to load stats:', error);
    }
  };

  const loadBots = async () => {
    try {
      const response = await apiService.getBots();
      setBots(response.bots || []);
      setLoading(false);
    } catch (error) {
      console.error('Failed to load bots:', error);
      setBots([]);
      setLoading(false);
    }
  };

  const handleCreateBot = () => {
    alert('创建机器人功能开发中...');
  };

  const handleBatchStart = () => {
    alert('批量启动功能开发中...');
  };

  const handleViewLogs = () => {
    window.location.href = '/logs';
  };

  return (
    <div className="flex w-screen h-screen">
      {/* 侧边栏 */}
      <aside className="w-64 bg-gradient-to-b from-indigo-900 to-purple-900 text-white flex flex-col flex-shrink-0">
        <div className="p-6 border-b border-indigo-700">
          <div className="flex items-center space-x-3">
            <div className="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center">
              <svg className="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"></path>
              </svg>
            </div>
            <div>
              <h1 className="font-bold text-lg">聊天系统</h1>
              <p className="text-indigo-200 text-xs">管理后台</p>
            </div>
          </div>
        </div>
        <nav className="flex-1 p-4 space-y-1 overflow-y-auto">
          <a href="#" className="sidebar-item active flex items-center space-x-3 px-4 py-3 rounded-lg transition text-white bg-white/15 border-r-4 border-indigo-500">
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
            </svg>
            <span>概览</span>
          </a>
          <Link to="/robots" className="sidebar-item flex items-center space-x-3 px-4 py-3 rounded-lg transition text-white hover:bg-white/10">
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>机器人管理</span>
          </Link>
          <Link to="/apikeys" className="sidebar-item flex items-center space-x-3 px-4 py-3 rounded-lg transition text-white hover:bg-white/10">
            <svg className="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path>
            </svg>
            <span>API Key 管理</span>
          </Link>
        </nav>
        <div className="p-4 border-t border-indigo-700 flex-shrink-0">
          <div className="flex items-center space-x-3">
            <div className="w-10 h-10 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center font-bold">管理员</div>
            <div>
              <p className="font-medium text-sm">邱总</p>
              <p className="text-indigo-200 text-xs">超级管理员</p>
            </div>
          </div>
        </div>
      </aside>

      {/* 主内容区 */}
      <main className="flex-1 overflow-y-auto bg-gray-50">
        <header className="bg-white border-b border-gray-200 px-8 py-4">
          <div className="flex items-center justify-between">
            <div>
              <h2 className="text-2xl font-bold text-gray-800">系统概览</h2>
              <p className="text-gray-500 text-sm mt-1">实时监控 100+ 机器人在线状态</p>
            </div>
          </div>
        </header>
        
        <div className="p-8">
          {/* 统计卡片 */}
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div className="bg-white rounded-xl p-6 shadow-sm card-hover transition">
              <p className="text-gray-500 text-sm">在线机器人</p>
              <p className="text-3xl font-bold text-gray-800 mt-2">{stats.onlineBots}</p>
              <p className="text-green-500 text-sm mt-1">↑ 12 较昨日</p>
            </div>
            <div className="bg-white rounded-xl p-6 shadow-sm card-hover transition">
              <p className="text-gray-500 text-sm">今日消息</p>
              <p className="text-3xl font-bold text-gray-800 mt-2">{stats.messages.toLocaleString()}</p>
              <p className="text-green-500 text-sm mt-1">↑ 8.5%</p>
            </div>
            <div className="bg-white rounded-xl p-6 shadow-sm card-hover transition">
              <p className="text-gray-500 text-sm">活跃用户</p>
              <p className="text-3xl font-bold text-gray-800 mt-2">1,234</p>
              <p className="text-green-500 text-sm mt-1">↑ 5.2%</p>
            </div>
            <div className="bg-white rounded-xl p-6 shadow-sm card-hover transition">
              <p className="text-gray-500 text-sm">API 调用</p>
              <p className="text-3xl font-bold text-gray-800 mt-2">{stats.apiKeys.toLocaleString()}</p>
              <p className="text-red-500 text-sm mt-1">↓ 2.1%</p>
            </div>
          </div>

          {/* 机器人实时状态 + 快捷操作 */}
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
            <div className="bg-white rounded-xl shadow-sm">
              <div className="p-6 border-b border-gray-200"><h3 className="font-bold text-gray-800">机器人实时状态</h3></div>
              <div className="p-6 space-y-4">
                {loading ? (
                  <div className="text-center py-8 text-gray-500">加载中...</div>
                ) : bots.length === 0 ? (
                  <div className="text-center py-8 text-gray-500">暂无机器人数据</div>
                ) : (
                  bots.slice(0, 3).map((bot) => (
                    <div key={bot.id} className="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
                      <div className="flex items-center space-x-3">
                        <div className="w-10 h-10 bg-blue-500 rounded-full flex items-center justify-center">
                          <span className="text-white font-bold">{bot.name.substring(0, 4)}</span>
                        </div>
                        <div>
                          <p className="font-medium">{bot.name} - {bot.model}</p>
                          <p className="text-gray-500 text-sm">ID: {bot.id}</p>
                        </div>
                      </div>
                      <div className="flex items-center space-x-4">
                        <div className={`w-2 h-2 rounded-full animate-pulse ${bot.status === 'online' ? 'bg-green-500' : 'bg-gray-400'}`}></div>
                        <span className={`text-sm font-medium ${bot.status === 'online' ? 'text-green-600' : 'text-gray-500'}`}>
                          {bot.status === 'online' ? '在线' : '离线'}
                        </span>
                        <span className="text-gray-400 text-sm">23 秒前活跃</span>
                      </div>
                    </div>
                  ))
                )}
              </div>
            </div>

            <div className="bg-white rounded-xl shadow-sm">
              <div className="p-6 border-b border-gray-200"><h3 className="font-bold text-gray-800">快捷操作</h3></div>
              <div className="p-6 space-y-3">
                <button onClick={handleCreateBot} className="w-full flex items-center space-x-3 p-4 bg-indigo-50 hover:bg-indigo-100 rounded-lg transition cursor-pointer">
                  <div className="w-10 h-10 bg-indigo-500 rounded-lg flex items-center justify-center">
                    <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                    </svg>
                  </div>
                  <div className="text-left">
                    <p className="font-medium text-gray-800">创建机器人</p>
                    <p className="text-gray-500 text-sm">新增机器人实例</p>
                  </div>
                </button>
                <button onClick={handleBatchStart} className="w-full flex items-center space-x-3 p-4 bg-green-50 hover:bg-green-100 rounded-lg transition cursor-pointer">
                  <div className="w-10 h-10 bg-green-500 rounded-lg flex items-center justify-center">
                    <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div className="text-left">
                    <p className="font-medium text-gray-800">批量启动</p>
                    <p className="text-gray-500 text-sm">同时启动多个机器人</p>
                  </div>
                </button>
                <button onClick={handleViewLogs} className="w-full flex items-center space-x-3 p-4 bg-purple-50 hover:bg-purple-100 rounded-lg transition cursor-pointer">
                  <div className="w-10 h-10 bg-purple-500 rounded-lg flex items-center justify-center">
                    <svg className="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div className="text-left">
                    <p className="font-medium text-gray-800">查看日志</p>
                    <p className="text-gray-500 text-sm">实时系统日志</p>
                  </div>
                </button>
              </div>
            </div>
          </div>
        </div>
      </main>
    </div>
  );
}

export default AdminPage;
